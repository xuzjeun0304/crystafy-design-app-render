NODE_ENV=development
PORT=8787

# Shopify store domain, for example: crystafy.myshopify.com
SHOPIFY_SHOP_DOMAIN=

# Custom app Admin API access token. Keep this private.
# Leave this empty when using a Dev Dashboard app with client credentials.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Dev Dashboard app credentials. Used to request a 24-hour Admin API token.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Shopify Admin API version.
SHOPIFY_API_VERSION=2026-01

# Shopify app client secret. Used to verify App Proxy and Webhook signatures.
SHOPIFY_API_SECRET=

# Public deployed backend URL, for example:
# https://crystafy-design-app-render.onrender.com
APP_BASE_URL=

# One-time setup password for /api/admin/install-webhooks.
CRYSTAFY_SETUP_TOKEN=

# Optional. Leave empty to deduct from the first available inventory location.
SHOPIFY_INVENTORY_LOCATION_ID=
DEDUCT_BEAD_INVENTORY_ON_ORDER=true
RESTOCK_BEAD_INVENTORY_ON_CANCEL=true
ARCHIVE_DESIGN_PRODUCTS_ON_FULFILLMENT=true
ALLOW_DESIGN_PRODUCT_DELETE=false
AUTO_CLEANUP_ARCHIVED_DESIGNS=false
AUTO_CLEANUP_OLDER_THAN_DAYS=30
AUTO_CLEANUP_INTERVAL_HOURS=24
AUTO_CLEANUP_LIMIT=250
DESIGN_ANALYTICS_WEBHOOK_URL=
DESIGN_ANALYTICS_WEBHOOK_TOKEN=

# Optional. Direct sync to customer NocoDB / ops.crystafy.com.
# Leave disabled until the Designs table and table id are ready.
NOCODB_DESIGN_SYNC_ENABLED=false
NOCODB_API_URL=https://ops.crystafy.com
NOCODB_API_TOKEN=
NOCODB_DESIGNS_TABLE_ID=

# Product visibility strategy for generated design products.
# DRAFT keeps one-off design products out of storefront search and collections.
DESIGN_PRODUCT_STATUS=DRAFT
PUBLISH_DESIGN_PRODUCTS=false
DESIGN_PRODUCT_TYPE=Custom Bracelet
DESIGN_PRODUCT_VENDOR=Crystafy
DESIGN_PRODUCT_TAGS=custom-design,hidden-design-product

# Local dev switch. Set true only for local testing before App Proxy is wired.
ALLOW_UNVERIFIED_LOCAL_REQUESTS=true

# Local dev switch. Set false after Shopify Admin API token is configured.
DRY_RUN_CREATE_PRODUCT=true
